# Ollama
ARCHON_OLLAMA_HOST=http://localhost:11434
ARCHON_MODEL=mistral:7b

# SearXNG
ARCHON_SEARXNG_URL=http://localhost:8080
ARCHON_SEARCH_TOP_N=5
ARCHON_SEARCH_CATEGORIES=general,it

# Set to false to skip Ollama and search with the raw query
ARCHON_REWRITE_QUERY=true

# Timeouts (in milliseconds)
ARCHON_REWRITE_TIMEOUT=3000
ARCHON_SEARCH_TIMEOUT=10000

# Number of retries on search failure
ARCHON_MAX_RETRIES=2
